.card { background: var(--card); border-radius: 16rpx; overflow: hidden; margin: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.cover { width: 100%; height: 360rpx; }
.info { padding: 20rpx; }
.title { font-size: 30rpx; font-weight: bold; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
