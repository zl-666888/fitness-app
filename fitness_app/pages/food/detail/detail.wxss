.food-card { }
.food-title { font-size: 36rpx; font-weight: bold; margin-bottom: 12rpx; }
.nutri-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.nutri-item { padding: 20rpx; background: #F9F9F9; border-radius: 12rpx; text-align: center; }
.nutri-value { font-size: 36rpx; font-weight: bold; }
.nutri-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }
.calc-input { gap: 16rpx; }
.amount-input { width: 150rpx; height: 70rpx; background: #F5F5F5; border-radius: 12rpx; text-align: center; font-size: 30rpx; }
.result-title { font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; }
.result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.result-item { padding: 20rpx; background: #F9F9F9; border-radius: 12rpx; text-align: center; }
.r-value { font-size: 32rpx; font-weight: bold; }
.r-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
