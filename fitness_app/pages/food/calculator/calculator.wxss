.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }
.search-input { background: #F5F5F5; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 28rpx; height: 70rpx; }
.search-btn { background: var(--primary); color: #fff; border-radius: 12rpx; font-size: 26rpx; padding: 0 24rpx; height: 70rpx; line-height: 70rpx; }
.selected-food { padding: 16rpx; background: #E8F5E9; border-radius: 8rpx; }
.amount-input { width: 200rpx; height: 80rpx; background: #F5F5F5; border-radius: 12rpx; text-align: center; font-size: 36rpx; }
.result-card { }
.result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.r-item { padding: 20rpx; background: #F9F9F9; border-radius: 12rpx; text-align: center; }
.r-value { font-size: 36rpx; font-weight: bold; }
.r-label { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.picker-overlay { position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.3); z-index: 100; display: flex; align-items: flex-end; }
.picker-sheet { background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 30rpx; width: 100%; max-height: 70vh; }
.picker-title { text-align: center; font-size: 32rpx; font-weight: bold; margin-bottom: 20rpx; }
.picker-list { max-height: 50vh; }
.picker-item { padding: 24rpx 0; border-bottom: 1rpx solid var(--border); }
