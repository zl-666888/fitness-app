.search-bar { padding: 20rpx; gap: 10rpx; }
.search-input { background: #fff; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 28rpx; height: 70rpx; }
.calc-btn { background: var(--accent); color: #fff; border-radius: 12rpx; font-size: 26rpx; padding: 0 20rpx; height: 70rpx; line-height: 70rpx; }
.filter-scroll { white-space: nowrap; padding: 0 10rpx 10rpx; }
.filter-item { display: inline-block; padding: 10rpx 24rpx; margin: 0 6rpx; border-radius: 20rpx; background: #fff; font-size: 26rpx; }
.filter-item.active { background: var(--accent); color: #fff; }
.load-more { text-align: center; padding: 30rpx; color: var(--text-secondary); font-size: 26rpx; }
