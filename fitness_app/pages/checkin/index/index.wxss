.header-card { background: linear-gradient(135deg, #4CAF50, #2E7D32); color: #fff; }
.date-text { font-size: 28rpx; opacity: 0.9; }
.status-text { font-size: 40rpx; font-weight: bold; margin-top: 10rpx; }
.checkin-btn { background: rgba(255,255,255,0.25); border-radius: 50%; width: 160rpx; height: 160rpx; display: flex; align-items: center; justify-content: center; }
.checkin-btn-text { color: #fff; font-size: 30rpx; font-weight: bold; text-align: center; }

.stats-row { margin: 20rpx; gap: 0; }
.stat-item { flex: 1; text-align: center; padding: 30rpx 0; background: #fff; border-right: 1rpx solid var(--border); }
.stat-item:last-child { border-right: none; }
.stat-num { font-size: 48rpx; font-weight: bold; color: var(--primary); }
.stat-label { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

.actions { display: flex; gap: 20rpx; }
.action-item { flex: 1; background: #fff; border-radius: 16rpx; padding: 30rpx; text-align: center; font-size: 28rpx; }
.action-icon { display: block; font-size: 48rpx; margin-bottom: 10rpx; }

.overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: flex-end; }
.sheet { background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 30rpx; width: 100%; max-height: 80vh; overflow-y: auto; }
.sheet-title { text-align: center; font-size: 34rpx; font-weight: bold; margin-bottom: 30rpx; }
.sheet-section { margin-bottom: 30rpx; }
.sheet-label { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.type-item { padding: 12rpx 24rpx; border-radius: 10rpx; background: #F5F5F5; font-size: 26rpx; }
.type-item.active { background: var(--primary); color: #fff; }
.int-item { flex: 1; text-align: center; padding: 16rpx; border-radius: 10rpx; background: #F5F5F5; font-size: 26rpx; }
.int-item.active { background: var(--accent); color: #fff; }
.submit-btn { width: 100%; height: 88rpx; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; border-radius: 12rpx; font-size: 32rpx; font-weight: bold; margin-top: 20rpx; }
