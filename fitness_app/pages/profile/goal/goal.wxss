.form-label { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.type-item { padding: 14rpx 32rpx; border-radius: 10rpx; background: #F5F5F5; font-size: 28rpx; }
.type-item.active { background: var(--accent); color: #fff; }
.form-item { margin-bottom: 30rpx; }
.form-input { width: 100%; height: 80rpx; background: #F5F5F5; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; }
.save-btn { width: 100%; height: 88rpx; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; border-radius: 12rpx; font-size: 32rpx; margin-top: 20rpx; }
