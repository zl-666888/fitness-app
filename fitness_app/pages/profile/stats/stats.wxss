.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.stat-card { padding: 30rpx; background: #F9F9F9; border-radius: 12rpx; text-align: center; }
.sc-value { font-size: 48rpx; font-weight: bold; }
.sc-label { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 16rpx; }
.date-tag { background: #E8F5E9; color: var(--primary); padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
