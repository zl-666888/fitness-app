.header-card { background: linear-gradient(135deg, #4CAF50, #2E7D32); padding: 50rpx 30rpx 30rpx; text-align: center; }
.header-stat { text-align: center; }
.hs-num { font-size: 40rpx; font-weight: bold; color: #fff; }
.hs-label { font-size: 22rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }
.menu-list { margin-top: 20rpx; background: #fff; }
.menu-item { padding: 30rpx; border-bottom: 1rpx solid #F5F5F5; font-size: 30rpx; }
.menu-item:last-child { border-bottom: none; }
