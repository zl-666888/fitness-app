<view class="page">
  <view class="header-card">
    <view class="avatar-lg avatar-placeholder-lg flex-center" wx:if="{{!user.avatar}}">👤</view>
    <image class="avatar-lg" wx:if="{{user.avatar}}" src="{{user.avatar}}" mode="aspectFill" />
    <view class="mt-20 text-bold" style="font-size:36rpx;color:#fff">{{user.nickname || user.username || '用户'}}</view>
    <view class="mt-10 text-sm" style="color:rgba(255,255,255,0.7)">{{user.phone || '未绑定手机'}}</view>
    <view class="flex-center mt-20 gap-20">
      <view class="header-stat"><view class="hs-num">{{stats.totalDays || 0}}</view><view class="hs-label">累计打卡</view></view>
      <view class="header-stat"><view class="hs-num">{{stats.consecutiveDays || 0}}</view><view class="hs-label">连续打卡</view></view>
      <view class="header-stat"><view class="hs-num">{{stats.currentMonthDays || 0}}</view><view class="hs-label">本月打卡</view></view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item flex-between" bindtap="goInfo">
      <text>👤 编辑资料</text>
      <text class="text-secondary">▶</text>
    </view>
    <view class="menu-item flex-between" bindtap="goGoal">
      <text>🎯 健身目标</text>
      <text class="text-secondary">▶</text>
    </view>
    <view class="menu-item flex-between" bindtap="goStats">
      <text>📊 运动统计</text>
      <text class="text-secondary">▶</text>
    </view>
    <view class="menu-item flex-between" bindtap="goFavorites">
      <text>❤️ 我的收藏</text>
      <text class="text-secondary">▶</text>
    </view>
    <view class="menu-item flex-between" bindtap="goFollowing">
      <text>👥 我的关注</text>
      <text class="text-secondary">▶</text>
    </view>
    <view class="menu-item flex-between" bindtap="goSettings">
      <text>⚙️ 设置</text>
      <text class="text-secondary">▶</text>
    </view>
  </view>
</view>
