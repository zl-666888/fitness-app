<view class="login-page">
  <view class="login-card">
    <view class="logo">🏃</view>
    <view class="title">创建账号</view>
    <view class="subtitle">开启你的健身之旅</view>
    <input class="input" placeholder="用户名 *" value="{{username}}" bindinput="onInput" data-field="username" />
    <input class="input" placeholder="密码 *" password value="{{password}}" bindinput="onInput" data-field="password" />
    <input class="input" placeholder="昵称（选填）" value="{{nickname}}" bindinput="onInput" data-field="nickname" />
    <input class="input" placeholder="手机号（选填）" value="{{phone}}" bindinput="onInput" data-field="phone" />
    <button class="login-btn" bindtap="handleRegister">注 册</button>
    <view class="footer">
      <text>已有账号？</text>
      <text class="link" bindtap="goLogin">去登录</text>
    </view>
  </view>
</view>
