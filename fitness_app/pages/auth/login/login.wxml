<view class="login-page">
  <view class="login-card">
    <view class="logo">🏃</view>
    <view class="title">健身打卡</view>
    <view class="subtitle">坚持运动，遇见更好的自己</view>
    <input class="input" placeholder="用户名" value="{{username}}" bindinput="onInput" data-field="username" />
    <input class="input" placeholder="密码" password value="{{password}}" bindinput="onInput" data-field="password" />
    <button class="login-btn" bindtap="handleLogin">登 录</button>
    <view class="footer">
      <text>还没有账号？</text>
      <text class="link" bindtap="goRegister">立即注册</text>
    </view>
  </view>
</view>
