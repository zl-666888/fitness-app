page { background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%); min-height: 100vh; }
.login-page { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 40rpx; }
.login-card { width: 100%; max-width: 600rpx; background: #fff; border-radius: 24rpx; padding: 60rpx 50rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15); }
.logo { text-align: center; font-size: 100rpx; margin-bottom: 20rpx; }
.title { text-align: center; font-size: 44rpx; font-weight: bold; color: #333; margin-bottom: 10rpx; }
.subtitle { text-align: center; font-size: 26rpx; color: #999; margin-bottom: 50rpx; }
.input { width: 100%; height: 90rpx; background: #F5F5F5; border-radius: 12rpx; padding: 0 24rpx; margin-bottom: 24rpx; font-size: 30rpx; box-sizing: border-box; }
.login-btn { width: 100%; height: 90rpx; background: linear-gradient(135deg, #4CAF50, #2E7D32); color: #fff; border-radius: 12rpx; font-size: 32rpx; font-weight: bold; display: flex; align-items: center; justify-content: center; margin-top: 20rpx; }
.footer { text-align: center; margin-top: 30rpx; font-size: 26rpx; color: #999; }
.link { color: #4CAF50; margin-left: 8rpx; font-weight: bold; }
