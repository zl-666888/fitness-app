.video-player { width: 100%; height: 420rpx; }
.cover-full { width: 100%; height: 420rpx; }
.cover-img { width: 100%; height: 100%; }

.placeholder-icon { font-size: 80rpx; display: block; text-align: center; }
.placeholder-text { font-size: 26rpx; color: #999; text-align: center; margin-top: 10rpx; display: block; }

.title { font-size: 34rpx; font-weight: bold; flex: 1; }
.fav-btn { padding: 10rpx 20rpx; border-radius: 8rpx; border: 1rpx solid var(--border); font-size: 26rpx; }
.fav-btn.favorited { background: #FFF0F0; color: var(--danger); border-color: var(--danger); }
.grid { display: flex; gap: 16rpx; }
.grid-item { flex: 1; text-align: center; padding: 20rpx; background: #F9F9F9; border-radius: 12rpx; }
.label { font-size: 24rpx; color: var(--text-secondary); display: block; }
.value { font-size: 28rpx; font-weight: bold; margin-top: 6rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 16rpx; }
