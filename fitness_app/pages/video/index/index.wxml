<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索视频..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" />
  </view>
  <scroll-view scroll-x class="filter-scroll">
    <view class="filter-item {{category === '' ? 'active' : ''}}" data-cat="" bindtap="onCategoryTap">全部</view>
    <view class="filter-item {{category === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" data-cat="{{item}}" bindtap="onCategoryTap">{{item}}</view>
  </scroll-view>
  <scroll-view scroll-x class="filter-scroll diff-scroll">
    <view class="filter-item {{difficulty === item.value ? 'active' : ''}}" wx:for="{{difficulties}}" wx:key="value" data-diff="{{item.value}}" bindtap="onDifficultyTap">{{item.label}}</view>
  </scroll-view>
  <video-card wx:for="{{videos}}" wx:key="id" item="{{item}}" bind:cardtap="goDetail" />
  <view class="load-more" wx:if="{{loading}}">加载中...</view>
  <view class="load-more" wx:if="{{!hasMore && videos.length > 0}}">— 已经到底了 —</view>
  <empty wx:if="{{!loading && videos.length === 0}}" icon="🎬" text="暂无视频" />
</view>
